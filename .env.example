# ===========================================
# Конфигурация парсера Hyperauto
# ===========================================
# Скопируйте этот файл в .env и измените значения при необходимости.
# Все значения необязательны — используются значения по умолчанию.

# -------------------------------------------
# Файлы
# -------------------------------------------
INPUT_FILE=товары.xlsx
OUTPUT_FILE_PREFIX=цены_гиперавто
COOKIES_FILE=cookies.json

# -------------------------------------------
# Настройки сайта
# -------------------------------------------
# Город (slug из URL hyperauto.ru)
CITY_SLUG=komsomolsk

# -------------------------------------------
# Таймауты и задержки (в секундах)
# -------------------------------------------
# Задержка между запросами
DELAY=5.0

# Таймаут загрузки страницы (мс)
TIMEOUT=25000

# Таймаут ожидания появления товаров (мс)
PAGE_LOAD_TIMEOUT=15000

# Задержка перед повторной попыткой (сек)
RETRY_DELAY=3.0

# -------------------------------------------
# Попытки
# -------------------------------------------
MAX_RETRIES=3

# -------------------------------------------
# Браузер
# -------------------------------------------
# Headless режим (1 для Docker, 0 для локального запуска)
DOCKER_ENV=0

# Размер окна браузера
VIEWPORT_WIDTH=1280
VIEWPORT_HEIGHT=900

# User-Agent
USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/124.0.0.0 Safari/537.36

# Локаль и таймзона
LOCALE=ru-RU
TIMEZONE_ID=Asia/Vladivostok

# -------------------------------------------
# Логирование
# -------------------------------------------
LOG_LEVEL=INFO
LOG_RETENTION_DAYS=30

# -------------------------------------------
# Excel
# -------------------------------------------
EXCEL_COLUMN_WIDTH_MIN=10
EXCEL_COLUMN_WIDTH_MAX=80
